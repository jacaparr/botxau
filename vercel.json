{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "vercel_app/index.html"
        }
    ],
    "env": {
        "VPS_URL": "http://37.60.247.231:5000"
    }
}